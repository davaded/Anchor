{
  "name": "anchor-workflow",
  "version": "0.1.2",
  "description": "Install Anchor skill workflows for Codex and Claude Code",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "anchor-workflow": "./dist/bin.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "sync-assets": "node ./scripts/sync-assets.mjs",
    "prepack": "pnpm sync-assets && pnpm build",
    "pack:check": "npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davaded/Anchor.git",
    "directory": "packages/installer"
  },
  "homepage": "https://github.com/davaded/Anchor",
  "dependencies": {
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0"
  }
}
